{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "linux-clang-debug",
            "inherits": "base",
            "displayName": "Linux Clang Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "ENABLE_CLANG_TIDY": "ON",
                "ENABLE_ASAN": "ON",
                "ENABLE_UBSAN": "ON"
            }
        },
        {
            "name": "linux-clang-release",
            "inherits": "base",
            "displayName": "Linux Clang Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "linux-clang-release-native",
            "inherits": "linux-clang-release",
            "displayName": "Linux Clang Release (native arch)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "ENABLE_NATIVE_ARCH": "ON"
            }
        },
        {
            "name": "linux-clang-release-static",
            "inherits": "linux-clang-release",
            "displayName": "Linux Clang Release (static)",
            "cacheVariables": {
                "ENABLE_STATIC_LINKING": "ON"
            }
        },
        {
            "name": "linux-clang-coverage",
            "inherits": "base",
            "displayName": "Linux Clang Coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "ENABLE_COVERAGE": "ON"
            }
        },
        {
            "name": "linux-clang-tsan",
            "inherits": "base",
            "displayName": "Linux Clang ThreadSanitizer",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "ENABLE_TSAN": "ON"
            }
        },
        {
            "name": "linux-gcc-debug",
            "inherits": "base",
            "displayName": "Linux GCC Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        },
        {
            "name": "linux-clang-pgo-instrument",
            "inherits": "linux-clang-release-native",
            "displayName": "Linux Clang PGO Instrumentation",
            "cacheVariables": {
                "ENABLE_PGO_INSTRUMENT": "ON"
            }
        },
        {
            "name": "linux-clang-pgo-optimize",
            "inherits": "linux-clang-release-native",
            "displayName": "Linux Clang PGO Optimized",
            "cacheVariables": {
                "ENABLE_PGO_OPTIMIZE": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "linux-clang-debug",
            "configurePreset": "linux-clang-debug"
        },
        {
            "name": "linux-clang-release",
            "configurePreset": "linux-clang-release"
        },
        {
            "name": "linux-clang-release-native",
            "configurePreset": "linux-clang-release-native"
        },
        {
            "name": "linux-clang-release-static",
            "configurePreset": "linux-clang-release-static"
        },
        {
            "name": "linux-clang-coverage",
            "configurePreset": "linux-clang-coverage"
        },
        {
            "name": "linux-clang-tsan",
            "configurePreset": "linux-clang-tsan"
        },
        {
            "name": "linux-gcc-debug",
            "configurePreset": "linux-gcc-debug"
        },
        {
            "name": "linux-clang-pgo-instrument",
            "configurePreset": "linux-clang-pgo-instrument"
        },
        {
            "name": "linux-clang-pgo-optimize",
            "configurePreset": "linux-clang-pgo-optimize"
        }
    ],
    "testPresets": [
        {
            "name": "linux-clang-debug",
            "configurePreset": "linux-clang-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-clang-release",
            "configurePreset": "linux-clang-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-clang-release-native",
            "configurePreset": "linux-clang-release-native",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-clang-release-static",
            "configurePreset": "linux-clang-release-static",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-clang-coverage",
            "configurePreset": "linux-clang-coverage",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-clang-tsan",
            "configurePreset": "linux-clang-tsan",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-gcc-debug",
            "configurePreset": "linux-gcc-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-clang-pgo-instrument",
            "configurePreset": "linux-clang-pgo-instrument",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-clang-pgo-optimize",
            "configurePreset": "linux-clang-pgo-optimize",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
